{
  "compilerOptions": {
    "target": "es2024",
    "module": "esnext",
    "jsx": "react",
    "lib": ["dom", "es2024"],
    "moduleResolution": "node",
    "sourceMap": true,
    "strict": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "importHelpers": true,
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src/**/*"]
}
